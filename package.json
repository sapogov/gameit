{
  "name": "gameit-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "dev:multiplayer": "concurrently -k -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b && vite build && node scripts/copy-spa-fallback.mjs",
    "build:server": "tsc -p server/tsconfig.json",
    "check:monster-rpg": "tsx scripts/monster-rpg-phase4-checks.ts",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.26",
    "@colyseus/sdk": "^0.17.42",
    "colyseus": "^0.17.10",
    "phaser": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
